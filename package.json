{
  "name": "docs-agent",
  "displayName": "docs-agent",
  "description": "documentation agent",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:docsAgent.updateDocsFromChanges",
    "onCommand:docsAgent.previewDocsUpdate"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docsAgent.previewDocsUpdate",
        "title": "Docs Agent: Preview docs update from git changes"
      },
      {
        "command": "docsAgent.updateDocsFromChanges",
        "title": "Docs Agent: Apply docs update from git changes"
      }
    ],
    "configuration": {
      "title": "Docs Agent",
      "properties": {
        "docsAgent.mode": {
          "type": "string",
          "enum": [
            "rules",
            "ai"
          ],
          "default": "rules",
          "description": "Planning mode. AI mode is guardrailed and only writes inside managed markers."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "node --test out/test/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
